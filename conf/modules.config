process {
    withName: 'FASTP' { ext.args = params.fastp_args; publishDir = [ path: { "${params.outdir}/qc/fastp" }, mode: params.publish_dir_mode ] }
    withName: 'FASTQC' { publishDir = [ path: { "${params.outdir}/qc/fastqc" }, mode: params.publish_dir_mode ] }
    withName: 'TRIMMOMATIC' { 
        ext.args = params.trimmomatic_args
        publishDir = [ path: { "${params.outdir}/qc/trimmomatic" }, mode: params.publish_dir_mode ] 
    }
    withName: 'BWA_ALIGN' { ext.args = params.bwa_args }
    withName: 'BOWTIE2_ALIGN' { ext.args = params.bowtie2_args }
    withName: 'MARK_DUPLICATES' { publishDir = [ path: { "${params.outdir}/aligned" }, mode: params.publish_dir_mode ] }
    withName: 'QUALIMAP' { publishDir = [ path: { "${params.outdir}/qc/qualimap" }, mode: params.publish_dir_mode ] }
    withName: 'GATK_CALL_LIB' { publishDir = [ path: { "${params.outdir}/variants/error_estimate_libraries" }, mode: params.publish_dir_mode ] }
    withName: 'FREEBAYES$' {
        ext.args = params.freebayes_args
        publishDir = [
            [
                path: { "${params.outdir}/variants/individual" },
                mode: params.publish_dir_mode,
                saveAs: { filename -> filename.endsWith('.vcf.gz') || filename.endsWith('.vcf.gz.tbi') ? filename : null }
            ],
            [
                path: { "${params.outdir}/variants/individual/freebayes_diagnostics" },
                mode: params.publish_dir_mode,
                saveAs: { filename ->
                    filename.contains('.freebayes_diagnostics/') || filename.endsWith('.freebayes_diagnostics')
                        ? filename.replaceFirst('^.*?([^/\\]+\\.freebayes_diagnostics(?:[/\\].*)?)$', '\$1')
                        : null
                }
            ]
        ]
    }
    withName: 'FREEBAYES_POPULATION' {
        ext.args = params.freebayes_args
        publishDir = [
            [
                path: { "${params.outdir}/variants/population" },
                mode: params.publish_dir_mode,
                saveAs: { filename -> filename.endsWith('.vcf.gz') || filename.endsWith('.vcf.gz.tbi') ? filename : null }
            ],
            [
                path: { "${params.outdir}/variants/population/freebayes_diagnostics" },
                mode: params.publish_dir_mode,
                saveAs: { filename ->
                    filename.contains('.freebayes_diagnostics/') || filename.endsWith('.freebayes_diagnostics')
                        ? filename.replaceFirst('^.*?([^/\\]+\\.freebayes_diagnostics(?:[/\\].*)?)$', '\$1')
                        : null
                }
            ]
        ]
    }
    withName: 'FREEBAYES_CALL_LIB' {
        ext.args = params.freebayes_args
        publishDir = [
            [
                path: { "${params.outdir}/variants/error_estimate_libraries" },
                mode: params.publish_dir_mode,
                saveAs: { filename -> filename.endsWith('.vcf.gz') || filename.endsWith('.vcf.gz.tbi') ? filename : null }
            ],
            [
                path: { "${params.outdir}/variants/error_estimate_libraries/freebayes_diagnostics" },
                mode: params.publish_dir_mode,
                saveAs: { filename ->
                    filename.contains('.freebayes_diagnostics/') || filename.endsWith('.freebayes_diagnostics')
                        ? filename.replaceFirst('^.*?([^/\\]+\\.freebayes_diagnostics(?:[/\\].*)?)$', '\$1')
                        : null
                }
            ]
        ]
    }
    withName: 'BCFTOOLS_CONCAT' { publishDir = [ path: { "${params.outdir}/variants/population" }, mode: params.publish_dir_mode ] }
    withName: 'VCF_ENSEMBLE_COMBINE' { publishDir = [ path: { "${params.outdir}/variants/ensemble" }, mode: params.publish_dir_mode ] }
    withName: 'GATK_HAPLOTYPECALLER' { ext.args = params.gatk_args; publishDir = [ path: { "${params.outdir}/variants/gatk_gvcfs" }, mode: params.publish_dir_mode ] }
    withName: 'GATK_COMBINEGVCFS' { publishDir = [ path: { "${params.outdir}/variants/gatk_cohort" }, mode: params.publish_dir_mode ] }
    withName: 'GATK_GENOTYPEGVCFS' { publishDir = [ path: { "${params.outdir}/variants/gatk" }, mode: params.publish_dir_mode ] }
    withName: 'BCFTOOLS_MERGE' { publishDir = [ path: { "${params.outdir}/variants/merged" }, mode: params.publish_dir_mode ] }
    withName: 'VCF_MULTI_COMPARE' { publishDir = [ path: { "${params.outdir}/error_estimates" }, mode: params.publish_dir_mode ] }
    withName: 'POPGEN_ANALYSES' { publishDir = [ path: { "${params.outdir}/population_genetics" }, mode: params.publish_dir_mode ] }
    withName: 'BCFTOOLS_STATS_RAW|BCFTOOLS_STATS_FILTERED' { publishDir = [ path: { "${params.outdir}/qc/bcftools" }, mode: params.publish_dir_mode ] }
    withName: 'MULTIQC' { publishDir = [ path: { "${params.outdir}/multiqc" }, mode: params.publish_dir_mode ] }
    withName: 'VCF_FILTER' { publishDir = [ path: { "${params.outdir}/variants/filtered" }, mode: params.publish_dir_mode ] }
}
