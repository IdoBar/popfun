process {
    withName: 'FASTP' { ext.args = params.fastp_args; publishDir = [ path: { "${params.outdir}/qc/fastp" }, mode: params.publish_dir_mode ] }
    withName: 'FASTQC' { publishDir = [ path: { "${params.outdir}/qc/fastqc" }, mode: params.publish_dir_mode ] }
    withName: 'TRIMMOMATIC' { 
        ext.args = params.trimmomatic_args
        publishDir = [ path: { "${params.outdir}/qc/trimmomatic" }, mode: params.publish_dir_mode ] 
    }
    withName: 'BWA_ALIGN' { ext.args = params.bwa_args }
    withName: 'BOWTIE2_ALIGN' { ext.args = params.bowtie2_args }
    withName: 'QUALIMAP' { publishDir = [ path: { "${params.outdir}/qc/qualimap" }, mode: params.publish_dir_mode ] }
    withName: 'GATK_CALL_LIB' { publishDir = [ path: { "${params.outdir}/variants/error_estimate_libraries" }, mode: params.publish_dir_mode ] }
    withName: 'FREEBAYES$' {
        ext.args = params.freebayes_args
        publishDir = [
            [
                path: { "${params.outdir}/variants/fb_ind" },
                mode: params.publish_dir_mode,
                pattern: "*.vcf.gz",
                saveAs: { filename ->
                    def normalized = filename.toString().replace('\\', '/')
                    return normalized.tokenize('/').last()
                }
            ],
            [
                path: { "${params.outdir}/variants/fb_ind" },
                mode: params.publish_dir_mode,
                pattern: "*.vcf.gz.tbi",
                saveAs: { filename ->
                    def normalized = filename.toString().replace('\\', '/')
                    return normalized.tokenize('/').last()
                }
            ],
            [
                path: { "${params.outdir}/variants/fb_ind/diagnostics" },
                mode: params.publish_dir_mode,
                pattern: "*.freebayes_diagnostics/*.tsv",
                saveAs: { filename ->
                    def normalized = filename.toString().replace('\\', '/')
                    return normalized.tokenize('/').last()
                }
            ]
        ]
    }
    withName: 'FREEBAYES_POPULATION$' {
        ext.args = params.freebayes_args
        publishDir = [
            [
                path: { "${params.outdir}/variants/fb_pop/diagnostics" },
                mode: params.publish_dir_mode,
                pattern: "*.freebayes_diagnostics/*.tsv",
                saveAs: { filename ->
                    def normalized = filename.toString().replace('\\', '/')
                    return normalized.tokenize('/').last()
                }
            ]
        ]
    }
    withName: 'FREEBAYES_CALL_LIB$' {
        ext.args = params.freebayes_args
        publishDir = [
            [
                path: { "${params.outdir}/variants/error_estimate_libraries" },
                mode: params.publish_dir_mode,
                pattern: "*.vcf.gz",
                saveAs: { filename ->
                    def normalized = filename.toString().replace('\\', '/')
                    return normalized.tokenize('/').last()
                }
            ],
            [
                path: { "${params.outdir}/variants/error_estimate_libraries" },
                mode: params.publish_dir_mode,
                pattern: "*.vcf.gz.tbi",
                saveAs: { filename ->
                    def normalized = filename.toString().replace('\\', '/')
                    return normalized.tokenize('/').last()
                }
            ],
            [
                path: { "${params.outdir}/variants/error_estimate_libraries/diagnostics" },
                mode: params.publish_dir_mode,
                pattern: "*.freebayes_diagnostics/*.tsv",
                saveAs: { filename ->
                    def normalized = filename.toString().replace('\\', '/')
                    return normalized.tokenize('/').last()
                }
            ]
        ]
    }
    withName: 'SAMTOOLS_SORT_ALIGN' {
        publishDir = [
            path: { "${params.outdir}/aligned" },
            mode: params.publish_dir_mode,
            saveAs: { filename ->
                if (params.save_bams == 'all') {
                    def normalized = filename.toString().replace('\\', '/')
                    def base = normalized.tokenize('/').last()
                    return "ind/${base}"
                }
                return null
            }
        ]
    }
    withName: 'SAMTOOLS_MERGE' {
        publishDir = [
            path: { "${params.outdir}/aligned" },
            mode: params.publish_dir_mode,
            saveAs: { filename ->
                if (params.save_bams in ['merged', 'all']) {
                    def normalized = filename.toString().replace('\\', '/')
                    def base = normalized.tokenize('/').last()
                    return "merged/${base}"
                }
                return null
            }
        ]
    }
    withName: 'BCFTOOLS_CONCAT' { publishDir = [ path: { "${params.outdir}/variants/fb_pop" }, mode: params.publish_dir_mode ] }
    withName: 'VCF_ENSEMBLE_COMBINE|VCF_ENSEMBLE_ASSEMBLE' { publishDir = [ path: { "${params.outdir}/variants/ensemble" }, mode: params.publish_dir_mode ] }
    withName: 'GATK_HAPLOTYPECALLER' { ext.args = params.gatk_args; publishDir = [ path: { "${params.outdir}/variants/gatk_ind" }, mode: params.publish_dir_mode ] }
    withName: 'GATK_COMBINEGVCFS' { publishDir = [ path: { "${params.outdir}/variants/gatk_merged" }, mode: params.publish_dir_mode ] }
    withName: 'GATK_GENOTYPEGVCFS' { publishDir = [ path: { "${params.outdir}/variants/gatk_joint" }, mode: params.publish_dir_mode ] }
    withName: 'BCFTOOLS_MERGE' { publishDir = [ path: { "${params.outdir}/variants/fb_merged" }, mode: params.publish_dir_mode ] }
    withName: 'VCF_MULTI_COMPARE' { publishDir = [ path: { "${params.outdir}/error_estimates" }, mode: params.publish_dir_mode ] }
    withName: 'POPGEN_ANALYSES' { publishDir = [ path: { "${params.outdir}/population_genetics" }, mode: params.publish_dir_mode ] }
    withName: 'BCFTOOLS_STATS_RAW|BCFTOOLS_STATS_FILTERED' { publishDir = [ path: { "${params.outdir}/qc/bcftools" }, mode: params.publish_dir_mode ] }
    withName: 'MULTIQC' { publishDir = [ path: { "${params.outdir}/multiqc" }, mode: params.publish_dir_mode ] }
    withName: 'VCF_FILTER' {
        publishDir = [
            path: { "${params.outdir}/variants" },
            mode: params.publish_dir_mode,
            saveAs: { filename ->
                def normalized = filename.toString().replace('\\', '/')
                def base = normalized.tokenize('/').last()

                if (base.startsWith('fb_pop.')) {
                    return "fb_pop/filtered/${base}"
                }
                if (base.startsWith('gatk_joint.')) {
                    return "gatk_joint/filtered/${base}"
                }
                if (base.startsWith('ensemble.')) {
                    return "ensemble/filtered/${base}"
                }

                // Library-level filtering outputs follow the existing error_estimate_libraries structure.
                return "error_estimate_libraries/filtered/${base}"
            }
        ]
    }
}
