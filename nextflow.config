params {
    // Input and reference files
    input           = ""
    outdir          = "results"
    ref             = ""
    annotation      = ""  // NEW: Optional path to .gff, .gff3, or .bed

    // Workflow control
    start_at        = 'qc' // 'qc', 'alignment', or 'call'
    stop_at         = 'filter' // 'qc', 'alignment', 'call', 'filter', or 'popgen'; MultiQC always runs last
    error_estimate  = false
    popgen          = false
    kmer_analysis   = false
    kmer            = 31
    popgen_tree_method = 'upgma'
    popgen_legend_order = 'samplesheet'

    // Tool choices (Options: 'fastp' or 'trimmomatic' for trimmer; 'bwa-mem2' or 'bowtie2' for aligner; 'freebayes' or 'gatk' for caller)
    trimmer         = 'fastp' // or 'trimmomatic'
    aligner         = 'bwa-mem2' // 'bowtie2'
    caller          = 'freebayes' // or 'gatk' or 'ensemble'
    ensemble_matcher = 'bcftools' // ensemble overlap engine: 'bcftools' (default) or 'rtg'
    error_estimate_caller = null // defaults to --caller, except --caller ensemble defaults to 'freebayes'; can be 'freebayes' or 'gatk'
    markdup_tool    = 'bamsormadup' // or 'gatk', 'sambamba', 'fastdup'
    save_bams       = 'none' // 'none' (default), 'merged', or 'all'
    freebayes_mode  = 'population' // or individual
    freebayes_region_splitter = 'coverage' // 'coverage' for coverage-balanced splitting or 'fai' for fasta_generate_regions.py
    freebayes_chunk_size = 100000   // chunk size passed to fasta_generate_regions.py for population Freebayes sharding
    freebayes_coverage_tool = 'mosdepth' // 'mosdepth' uses interval-to-coverage conversion; 'sambamba' uses sambamba depth base
    freebayes_coverage_regions = 500 // target number of coverage-balanced regions when freebayes_region_splitter='coverage'
    freebayes_max_chunks = 2000 // abort Freebayes region fan-out if the largest per-chromosome region file exceeds this limit
    freebayes_debug = false // save Freebayes per-region stderr and TSV diagnostics only when true
    ploidy          = 2              // Set to 2 by default to enable heterozygote detection/filtering

    // Aligner Indices (Optional: If null, pipeline will build them)
    bwa_index       = null
    bowtie2_index   = null

    // Filtering thresholds
    filter_qual     = 30
    filter_min_dp   = 10
    filter_max_dp   = 100000
    filter_ind_dp   = 7
    mask_hetero     = true           // Masks heterozygous genotypes during filtering; requires diploid variant calling (--ploidy 2)

    // Custom arguments for tools (Optional)
    fastp_args      = ""
    trimmomatic_args = "ILLUMINACLIP:TruSeq3-PE.fa:2:30:10 LEADING:3 TRAILING:3 SLIDINGWINDOW:4:15 MINLEN:36"
    kmer_sourmash_args = ""
        kmer_sourmash_compare_args = ""
    kmer_kat_args   = ""
        kmer_kat_threads = 1
    kmer_sourmash_k = 31
    kmer_sourmash_scaled = 1000
    bwa_args        = ""
    bowtie2_args    = ""
    gatk_args       = ""
    freebayes_args  = "--genotype-qualities --use-best-n-alleles 4"

    // Custom MultiQC configuration file (Optional)
    multiqc_config = "$baseDir/assets/multiqc_config.yaml"

    publish_dir_mode = 'copy'
}

includeConfig 'conf/base.config'
includeConfig 'conf/modules.config'

profiles {
    test {
        params.input = "$baseDir/assets/samplesheet.csv"
        params.ref = "https://zenodo.org/records/19284335/files/ref.fa.gz"
        params.annotation = "https://zenodo.org/records/19284335/files/ref.gff3"
        params.outdir = "results_test"

        process {
            // Downsize high/medium resource modules for lightweight test runs.
            withName: 'FREEBAYES_POPULATION' {
                cpus = 2
                memory = 6.GB
                time = 4.h
            }

            withName: 'FREEBAYES$|GATK_HAPLOTYPECALLER|SAMTOOLS_MERGE|SAMTOOLS_INDEX_INPUT_BAM|MARK_DUPLICATES.+|QUALIMAP|FREEBAYES_CALL_LIB|FASTP|FASTQC|MULTIQC|TRIMMOMATIC|.+_INDEX|.+_ALIGN|FREEBAYES_COVERAGE.+|FREEBAYES_SPLIT_REGIONS.+' {
                cpus = 2
                memory = 6.GB
                time = 1.h
            }

            withName: 'SOURMASH_SKETCH|SOURMASH_COMPARE|KAT_HIST|KAT_GCP' {
                cpus = 2
                memory = 6.GB
                time = 1.h
            }

            withName: 'GATK_COMBINEGVCFS|GATK_GENOTYPEGVCFS|GATK_CALL_LIB|POPGEN_ANALYSES|VCF_FILTER|BCFTOOLS_.+|VCF_ENSEMBLE_.+|GENERATE_SOFTWARE_VERSIONS_MQC|DECOMPRESS_FASTA|SAMTOOLS_FAIDX|GATK_DICTIONARY|GFF_TO_BED|VCF_MULTI_COMPARE|VCF_DISCORDANCE_MQC' {
                cpus = 1
                memory = 4.GB
                time = 1.h
            }
        }
    }
    docker {
        docker.enabled = true
        docker.runOptions = '-u $(id -u):$(id -g)'
    }
    singularity {
        singularity.enabled = true
        singularity.autoMounts = true
    }
    apptainer {
        apptainer.enabled = true
        apptainer.autoMounts = true
    }
    conda {
        conda.enabled = true
        conda.useMamba = true
    }
}
